# ==========================================
# AgroChain Backend Configuration
# ==========================================

# --- API ---
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# --- Security ---
SECRET_KEY=generate_a_strong_secret_key_here
ALGORITHM=HS256

# --- E.Land.gov.ua (Кадастр) ---
# Отримайте на: https://e.land.gov.ua/api/oauth/token
CADASTRE_CLIENT_ID=your_cadastre_client_id
CADASTRE_CLIENT_SECRET=your_cadastre_client_secret

# --- UKAS CertCheck ---
# Партнерський доступ: accreditation@ukas.com
UKAS_API_KEY=your_ukas_api_key_if_available

# --- Держпродспоживслужба (Phyto) ---
PHYTO_API_KEY=your_phyto_api_key_if_available

# --- eCherha (Черга) ---
ECHERHA_LOGIN=transport_company_login
ECHERHA_PASSWORD=transport_company_password

# --- Solana Blockchain ---
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PAYER_KEYPAIR=keypair.json
GRAIN_REGISTRY_PROGRAM_ID=GrainXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TRADE_ESCROW_PROGRAM_ID=EscrowXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- MQTT (GPS) ---
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://agrochain:password@postgres/agrochain

# --- NGSI-LD (FIWARE) ---
NGSI_LD_BROKER=http://orion-ld:1026
